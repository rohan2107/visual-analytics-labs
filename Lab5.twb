  <worksheets>
    <worksheet name='Computing Z-Scores'>
      <table>
        <view>
          <datasources>
            <datasource name='Sample - EU Superstore' />
          </datasources>
          <datasource-dependencies datasource='Sample - EU Superstore'>
            <column caption='AverageSales' datatype='real' name='[Calculation_0780695256473602]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_AVG(SUM([Sales]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='STDEVsales' datatype='real' name='[Calculation_0780695256760323]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_STDEV(SUM([Sales]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='ZScore' datatype='real' name='[Calculation_0780695256895492]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Sales]) - [Calculation_0780695256473602]) / [Calculation_0780695256760323]'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Country/Region]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
