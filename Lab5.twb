      <aliases enabled='yes' />
      <column caption='Cat or SubCat' datatype='string' name='[Calculation_0780695234445312]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 4]= [Category] THEN [Sub-Category]&#13;&#10;ELSE [Category]&#13;&#10;END' />
      </column>
      <column caption='Colouring' datatype='boolean' name='[Calculation_0780695254089729]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([Sales])&gt;[Parameters].[Parameter 6]' />
      </column>
      <column caption='CorrelationCoefficient' datatype='real' name='[Calculation_0780695259209733]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR({INCLUDE [Customer Name]:SUM([Sales (Orders1)])},{INCLUDE [Customer Name]:SUM([Sales])})' />
      </column>
      <column caption='NotSameSubCategoryFilter' datatype='boolean' name='[Calculation_0780695259762694]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Sub-Category]!=[Sub-Category (Orders1)]' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
